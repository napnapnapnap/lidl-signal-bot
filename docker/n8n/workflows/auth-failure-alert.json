        "body": "={{ JSON.stringify({ message: '⚠️ Lidl auth has expired. SSH into the VM and run: make reauth', number: $env.SIGNAL_PHONE_NUMBER, recipients: [$env.SIGNAL_GROUP_ID] }) }}",
        "options": {}
      }
    }
  ],
  "connections": {
    "Error Trigger": {
      "main": [[{"node": "Send Auth Alert", "type": "main", "index": 0}]]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  },
  "id": "auth-failure-alert"
}
